{
  "name": "exec-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:dashboard": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "luxon": "^3.6.1",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/luxon": "^3.6.2",
    "@types/node": "^22.15.32",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^8.1.0"
  }
}
