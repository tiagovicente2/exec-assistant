{
  "name": "exec-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun --watch src/server/index.ts",
    "dev:dashboard": "bunx vite --host 0.0.0.0",
    "build": "bunx tsc -p tsconfig.json && bunx vite build",
    "start": "bun dist/server/index.js",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/supabase-js": "^2.50.0",
    "@tailwindcss/vite": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^1.22.0",
    "luxon": "^3.6.1",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "react": "^18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/luxon": "^3.6.2",
    "@types/node": "^22.15.32",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^8.1.0"
  }
}
